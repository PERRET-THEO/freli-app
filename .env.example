VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Copier les mêmes clés dans Vercel → Project → Settings → Environment Variables (Production / Preview).

# --- Secrets Supabase Edge Functions (Dashboard → Project → Edge Functions → Secrets) ---
# Requis pour Stripe Connect + Checkout :
# STRIPE_SECRET_KEY=sk_test_...     # clé secrète du compte PLATEFORME (Connect)
# STRIPE_WEBHOOK_SECRET=whsec_...   # signing secret du endpoint webhook (account.updated, checkout.session.completed)
# APP_URL=https://...               # URL publique du front (success/cancel Checkout + return Stripe Connect)
# Optionnel :
# STRIPE_CONNECT_DEFAULT_COUNTRY=FR # pays des comptes Express créés via l’API
#
# Stripe Dashboard : activer Connect (Express), ajouter l’URL de la fonction stripe-webhook
# (ex. https://<project-ref>.supabase.co/functions/v1/stripe-webhook) et les événements ci-dessus.

# --- Invite User (Auth) ---
# Edge Function invite-user utilise APP_URL pour redirectTo : ${APP_URL}/signup
# Déployer : supabase functions deploy invite-user
#
# Template email Supabase « Invite User » — bouton (exemple) :
#   <a href="{{ .ConfirmationURL }}&email={{ .Email }}">Accepter l'invitation</a>
# (.Email est la variable documentée ; si ton template utilise un autre nom, aligne-le.)
# Ne pas remplacer {{ .ConfirmationURL }} par une URL Freli en dur.
# Redirect URLs : inclure https://freli-app.vercel.app/signup (et /signup en local si besoin).
